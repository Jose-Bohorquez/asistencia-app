# ─── Credenciales y entorno — NUNCA versionar ────────────────────────────────
.env
.env.local
.env.production
config/env.local.php

# ─── Archivos de debug y pruebas manuales ────────────────────────────────────
debug_*.php
test_*.php
credenciales_prueba.txt

# ─── Storage: archivos subidos por usuarios ──────────────────────────────────
# Mantener la estructura de carpetas con .gitkeep, pero no los archivos reales
storage/perfiles/*
!storage/perfiles/.gitkeep
storage/temp/
uploads/temp/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Dependencias ────────────────────────────────────────────────────────────
vendor/
node_modules/

# ─── Cache ───────────────────────────────────────────────────────────────────
cache/
*.cache
*.tmp
*.temp

# ─── Backup ──────────────────────────────────────────────────────────────────
*.bak
*.backup

# ─── Sistema operativo ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db

